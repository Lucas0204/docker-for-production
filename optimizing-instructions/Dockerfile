FROM node:24.0.0-slim AS ci

USER node

# The construction of the Dockerfile must be based on how much instructions may change.
# Instructions that do not change or rarely change, should always be placed at the top of the Dockerfile
# so that they can be cached and reused in subsequent builds, which can significantly reduce the build time.
# ENV, ARG, USER, WORKDIR, RUN apt update, apt install, etc...

# Run mkdir so that the directory is owned by the node user instead of root
RUN mkdir /src/node/app
# WORKDIR uses the directory already created, otherwise it will be created by root and cause permission issues
WORKDIR /src/node/app


# ADD is better than: RUN wget ${URL}
# because it can use the layer cache and it can also verify the checksum of the file to ensure that it is not corrupted or tampered with.
ADD --checksum=... http://ftp.de.debian.org/debian/pool/main/c/curl/curl_7.88.1-10+deb12u14_amd64.deb /tmp/curl.deb

# Another benefit of using ADD is that it can automatically extract the file if it is an archive, such as tar.gz, zip, etc.
# This can save us from having to run additional commands to extract the file after downloading, as well as using the layer's cache
# gzip, bzip2 or xz
ADD curl-8.15.0.tar.gz /tmp/test


# Deterministic instructions and non-deterministic instructions:
RUN echo "This is a deterministic command" > deterministic.txt
# The above instruction is a deterministic instruction because it will always produce the same output regardless of when it is run.

RUN date > non-deterministic.txt
# The above instruction is a non-deterministic instruction
# because it will produce different output each time it is run due to the inclusion of the date command,
# which generates a timestamp that changes with each execution.
# Non-deterministic instructions should be used with caution as they can lead to builds with low predictability.
# In some cases, they can even be replaced by ARG or ENV to make execution more predictable. E.g. the above instruction can be replaced by:

ARG BUILD_TIMESTAMP
RUN echo "$BUILD_TIMESTAMP" > build_timestamp.txt


# Instructions that install dependencies, should always be in the same layer
# so if there are changes in the instruction, `apt update` will not be skipped so the dependencies will not break.
# Also, the less layers we have, the better performance we can get and reducing final image size
# `rm -rf /var/lib/apt/lists/*` is important to clean up the trash generated by apt that does not need to be included in the final image
RUN apt update && apt install -y curl git && \
  rm -rf /var/lib/apt/lists/*


RUN --mount=type=bind,source=package.json,target=package.json \
  --mount=type=bind,source=package-lock.json,target=package-lock.json \
  --mount=type=cache,target=/src/node/.npm,uid=1000,gid=1000,id=npm-cache \
  npm ci

COPY --chown=node:node . .

CMD ["tail", "-f", "/dev/null"]

FROM node:24.0.0-slim AS builder

ENV NODE_ENV=production

USER node

RUN mkdir /src/node/app
WORKDIR /src/node/app

COPY --chown=node:node --from=ci /src/node/app .
RUN npm run build

RUN --mount=type=bind,source=package.json,target=package.json \
  --mount=type=bind,source=package-lock.json,target=package-lock.json \
  --mount=type=cache,target=/src/node/.npm,uid=1000,gid=1000,id=npm-cache \
  npm ci --only=production

FROM node:24.0.0-slim AS production

ENV NODE_ENV=production

USER node

RUN mkdir /src/node/app
WORKDIR /src/node/app

COPY --chown=node:node --from=builder /src/node/app/dist ./dist
COPY --chown=node:node --from=builder /src/node/app/node_modules ./node_modules
COPY --chown=node:node --from=builder /src/node/app/package.json ./

EXPOSE 3000

CMD ["node", "dist/main.js"]
